#:kivy 2.2.0

<GameWidget>:
    # 使用 FloatLayout 作为根布局，方便自适应
    canvas:
        Color:
            rgba: 245/255, 245/255, 245/255, 1  # 背景色 #F5F5F5
        Rectangle:
            pos: self.pos
            size: self.size

    # 顶部工具栏
    BoxLayout:
        orientation: 'horizontal'
        size_hint: 1, 0.08
        pos_hint: {'top': 1}
        padding: [10, 5]
        spacing: 10
        canvas.before:
            Color:
                rgba: 224/255, 224/255, 224/255, 1  # #E0E0E0
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: '业闲 - 五子棋'
            font_size: '16sp'
            bold: True
            color: 51/255, 51/255, 51/255, 1
            size_hint_x: 0.22

        Label:
            id: current_player_label
            text: '当前: 黑棋'
            font_size: '12sp'
            color: 51/255, 51/255, 51/255, 1
            size_hint_x: 0.15

        Label:
            id: move_count_label
            text: '步数: 0'
            font_size: '12sp'
            color: 51/255, 51/255, 51/255, 1
            size_hint_x: 0.12

        Label:
            id: status_label
            text: '游戏中...'
            font_size: '12sp'
            bold: True
            color: 0, 102/255, 0, 1  # #006600
            size_hint_x: 0.18

        Label:
            id: mode_label
            text: '模式: 双人对战'
            font_size: '12sp'
            color: 51/255, 51/255, 51/255, 1
            size_hint_x: 0.18

    # 主内容区域：左侧棋盘 + 右侧信息面板
    BoxLayout:
        orientation: 'horizontal'
        size_hint: 1, 0.92
        pos_hint: {'top': 0.93}
        padding: [10, 5]

        # 左侧棋盘容器
        RelativeLayout:
            id: board_container
            size_hint_x: 0.62
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        # 右侧信息面板
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.38
            padding: [10, 10]
            spacing: 8
            canvas.before:
                Color:
                    rgba: 248/255, 248/255, 248/255, 1  # #F8F8F8
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 153/255, 153/255, 153/255, 1
                Line:
                    rectangle: self.x, self.y, self.width, self.height
                    width: 1

            # 游戏信息标题
            Label:
                text: '游戏信息'
                font_size: '14sp'
                bold: True
                color: 51/255, 51/255, 51/255, 1
                size_hint_y: 0.06

            # 棋子颜色示例
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.09
                spacing: 3
                BoxLayout:
                    size_hint_y: 0.5
                    spacing: 5
                    Widget:
                        canvas:
                            Color:
                                rgba: 0,0,0,1
                            Ellipse:
                                pos: self.center_x - 12, self.center_y - 12
                                size: 24, 24
                            Color:
                                rgba: 102/255,102/255,102/255,1
                            Line:
                                circle: self.center_x, self.center_y, 12
                    Label:
                        text: '黑棋 (先手)'
                        font_size: '11sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size
                BoxLayout:
                    size_hint_y: 0.5
                    spacing: 5
                    Widget:
                        canvas:
                            Color:
                                rgba: 1,1,1,1
                            Ellipse:
                                pos: self.center_x - 12, self.center_y - 12
                                size: 24, 24
                            Color:
                                rgba: 102/255,102/255,102/255,1
                            Line:
                                circle: self.center_x, self.center_y, 12
                    Label:
                        text: '白棋'
                        font_size: '11sp'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.size

            # 模式选择
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.1
                spacing: 5
                Label:
                    text: '游戏模式:'
                    font_size: '12sp'
                    bold: True
                    color: 51/255, 51/255, 51/255, 1
                    size_hint_y: 0.4
                BoxLayout:
                    spacing: 5
                    size_hint_y: 0.6
                    Button:
                        id: two_player_btn
                        text: '双人对战'
                        font_size: '10sp'
                        background_normal: ''
                        background_color: 76/255, 175/255, 80/255, 1  # #4CAF50
                        color: 1,1,1,1
                        on_release: root.set_two_player_mode()
                    Button:
                        id: vs_ai_btn
                        text: '人机对战'
                        font_size: '10sp'
                        background_normal: ''
                        background_color: 33/255, 150/255, 243/255, 1  # #2196F3
                        color: 1,1,1,1
                        on_release: root.set_vs_ai_mode()

            # 规则说明
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.28
                spacing: 2
                Label:
                    text: '游戏规则:'
                    font_size: '12sp'
                    bold: True
                    color: 51/255, 51/255, 51/255, 1
                    size_hint_y: 0.2
                Label:
                    text: '1. 黑棋先行，轮流下棋\n2. 横、竖、斜连成五子获胜\n3. 棋盘下满为平局\n4. 点击棋盘交叉点下棋'
                    font_size: '10sp'
                    color: 85/255, 85/255, 85/255, 1
                    halign: 'left'
                    valign: 'top'
                    text_size: self.width, self.height

            # 操作说明
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.23
                spacing: 2
                Label:
                    text: '操作说明:'
                    font_size: '12sp'
                    bold: True
                    color: 51/255, 51/255, 51/255, 1
                    size_hint_y: 0.2
                Label:
                    text: '• 触摸点击: 落子\n• 点击下方按钮悔棋/重开/退出'
                    font_size: '10sp'
                    color: 85/255, 85/255, 85/255, 1
                    halign: 'left'
                    valign: 'top'
                    text_size: self.width, self.height

            # 按钮区域
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.16
                spacing: 5
                Button:
                    text: '重新开始'
                    font_size: '11sp'
                    background_normal: ''
                    background_color: 76/255, 175/255, 80/255, 1
                    color: 1,1,1,1
                    on_release: root.restart_game()
                Button:
                    text: '悔棋'
                    font_size: '11sp'
                    background_normal: ''
                    background_color: 33/255, 150/255, 243/255, 1
                    color: 1,1,1,1
                    on_release: root.undo_move()
                Button:
                    text: '退出游戏'
                    font_size: '11sp'
                    background_normal: ''
                    background_color: 244/255, 67/255, 54/255, 1
                    color: 1,1,1,1
                    on_release: root.quit_game()